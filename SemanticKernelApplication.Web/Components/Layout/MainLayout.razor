@inherits LayoutComponentBase

<div class="shell">
    <header class="shell-header">
        <div>
            <p class="shell-eyebrow">Semantic Kernel Application</p>
            <h1>Agent Workbench</h1>
        </div>
        <p class="shell-copy">Interactive Server Blazor host for plain-language agent creation, coordinator chat, and live runtime activity.</p>
    </header>

    <main class="shell-main">
        <article class="shell-content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>
