@page "/"
@rendermode InteractiveServer

<PageTitle>Agent Workbench</PageTitle>

<div class="workbench">
    <section class="hero-card">
        <div>
            <p class="eyebrow">Coordinator-driven agent studio</p>
            <h2>Talk to one coordinator, let it create specialists from natural language, and follow the workbench in plain English.</h2>
        </div>

        <div class="hero-stats">
            <article>
                <span>@Agents.Count</span>
                <small>Agents</small>
            </article>
            <article>
                <span>@Providers.Count</span>
                <small>Models</small>
            </article>
            <article>
                <span>@ActivityFeed.Count</span>
                <small>Live events</small>
            </article>
        </div>
    </section>

    <section class="setup-card">
        <div class="setup-copy">
            <p class="panel-label">Setup</p>
            <h3>Choose one global model and one constrained workspace for the whole bench.</h3>
            <p>API keys stay in memory for this app session and are not stored in the repo config.</p>
        </div>

        <div class="setup-grid">
            <div class="setup-field">
                <label for="workspace-path">Workspace folder</label>
                <div class="setup-row">
                    <input id="workspace-path"
                           list="workspace-path-suggestions"
                           @bind="WorkspacePathInput"
                           @bind:event="oninput"
                           placeholder="C:\Projects\SemanticKernelApplication" />
                    <button class="primary-button" @onclick="ApplyWorkspaceAsync" disabled="@(!CanApplyWorkspace)">
                        @(IsWorkspaceBusy ? "Applying..." : "Apply")
                    </button>
                </div>
                <datalist id="workspace-path-suggestions">
                    @foreach (var suggestion in WorkspaceSuggestions)
                    {
                        <option value="@suggestion"></option>
                    }
                </datalist>
                <small>Active: @ActiveWorkspacePath</small>
            </div>

            <div class="setup-field">
                <label for="global-provider">Global model</label>
                <div class="setup-row">
                    <select id="global-provider" @bind="SelectedProviderId">
                        @foreach (var provider in Providers)
                        {
                            <option value="@provider.Id">@provider.DisplayName (@provider.Kind)</option>
                        }
                    </select>
                    <button class="primary-button" @onclick="ApplyModelAsync" disabled="@(!CanApplyModel)">
                        @(IsModelBusy ? "Updating..." : "Apply")
                    </button>
                </div>
                <small>Current: @CurrentModelLabel</small>
            </div>

            <div class="setup-field">
                <label for="api-key">API key for the selected model</label>
                <input id="api-key"
                       type="password"
                       @bind="ApiKeyInput"
                       @bind:event="oninput"
                       placeholder="Paste a key for the selected provider" />
                <small>@(ApiKeyConfigured ? "A session key is loaded for the current model." : "No session key loaded for the current model.")</small>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(SetupFeedback))
        {
            <p class="setup-feedback">@SetupFeedback</p>
        }
    </section>

    <section class="workbench-grid">
        <div class="panel chat-panel">
            <div class="panel-header">
                <div>
                    <p class="panel-label">Coordinator chat</p>
                    <h3>Ask for work or tell the coordinator to create a new agent</h3>
                </div>
            </div>

            <div class="conversation">
                @if (Messages.Count == 0)
                {
                    <div class="empty-state">
                        <strong>No conversation yet</strong>
                        <p>Try: "Create an agent that reviews backend architecture and async flows."</p>
                    </div>
                }
                else
                {
                    @foreach (var message in Messages)
                    {
                        var isUser = message.AuthorId == "user";
                        <article class="@(isUser ? "message message-user" : "message")">
                            <div class="message-meta">
                                <strong>@ResolveAuthor(message.AuthorId)</strong>
                                <span>@message.CreatedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                            <p>@message.Content</p>
                        </article>
                    }
                }
            </div>

            <div class="composer">
                <label for="chat-message">Brief the coordinator</label>
                <textarea id="chat-message" rows="5" @bind="ChatMessage" placeholder="Example: Create an agent that reviews PRs for security regressions, then summarize how it will help the team."></textarea>
                <div class="composer-actions">
                    <span>@(IsBusy ? "Coordinator is working..." : "Ready")</span>
                    <button class="primary-button" @onclick="SendAsync" disabled="@IsBusy">Send</button>
                </div>
            </div>
        </div>

        <div class="panel output-panel">
            <div class="panel-header">
                <div>
                    <p class="panel-label">Live output</p>
                    <h3>Public progress only</h3>
                </div>
            </div>

            <div class="activity-stream">
                @if (ActivityFeed.Count == 0)
                {
                    <div class="empty-state">
                        <strong>No activity yet</strong>
                        <p>Runtime events will appear here as the coordinator receives work and agents respond.</p>
                    </div>
                }
                else
                {
                    @foreach (var entry in ActivityFeed)
                    {
                        <article class="activity-entry">
                            <div class="activity-header">
                                <strong>@entry.Title</strong>
                                <span>@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                            <p>@entry.Message</p>
                        </article>
                    }
                }
            </div>
        </div>

        <div class="panel studio-panel">
            <div class="panel-header">
                <div>
                    <p class="panel-label">Agent studio</p>
                    <h3>Created specialists appear here automatically</h3>
                </div>
            </div>

            <div class="studio-form">
                <label for="agent-description">Create directly from the studio if needed</label>
                <textarea id="agent-description" rows="5" @bind="AgentDescription" placeholder="Example: A frontend specialist that critiques mobile layouts and interaction flow."></textarea>
                <button class="primary-button" @onclick="CreateAgentAsync" disabled="@IsBusy">Create agent</button>
            </div>

            <div class="agent-list">
                @if (Agents.Count == 0)
                {
                    <div class="empty-state">
                        <strong>No agents created yet</strong>
                        <p>The coordinator can create them for you from the chat panel.</p>
                    </div>
                }
                else
                {
                    @foreach (var agent in Agents)
                    {
                        <article class="agent-card">
                            <div class="agent-topline">
                                <strong>@agent.Name</strong>
                                <span>@CurrentModelLabel</span>
                            </div>
                            <p class="agent-role">@agent.Description</p>
                            <p class="agent-prompt">@agent.Instructions.SystemPrompt</p>
                        </article>
                    }
                }
            </div>
        </div>
    </section>
</div>
