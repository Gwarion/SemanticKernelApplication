@page "/"
@rendermode InteractiveServer

<PageTitle>Agent Workbench</PageTitle>

<div class="workbench">
    <section class="setup-card">
        <div class="setup-header">
            <div>
                <p class="panel-label">Setup</p>
                <h3>Saved local configuration</h3>
            </div>
            <div class="setup-stats">
                <span>@Agents.Count agents</span>
                <span>@Providers.Count providers</span>
                <span>@KnownWorkspacePaths.Count workspaces</span>
            </div>
        </div>

        <div class="setup-grid">
            <div class="setup-field">
                <label for="workspace-path">Saved workspace</label>
                <div class="setup-row">
                    <select id="workspace-path" @bind="WorkspacePathInput">
                        @foreach (var workspacePath in WorkspaceSuggestions)
                        {
                            <option value="@workspacePath">@workspacePath</option>
                        }
                    </select>
                    <button class="primary-button" @onclick="ApplyWorkspaceAsync" disabled="@(!CanApplyWorkspace)">
                        @(IsWorkspaceBusy ? "Applying..." : "Use")
                    </button>
                </div>
                <small>Active: @ActiveWorkspacePath</small>
            </div>

            <div class="setup-field">
                <label for="new-workspace-path">Add workspace</label>
                <div class="setup-row">
                    <input id="new-workspace-path"
                           @bind="NewWorkspacePathInput"
                           @bind:event="oninput"
                           placeholder="C:\Projects\AnotherWorkspace" />
                    <button class="primary-button" @onclick="AddWorkspaceAsync" disabled="@(!CanAddWorkspace)">
                        @(IsWorkspaceBusy ? "Adding..." : "Add")
                    </button>
                </div>
                <small>Adds the folder to the saved workspace list and selects it immediately.</small>
            </div>

            <div class="setup-field">
                <label for="global-provider">Provider</label>
                <div class="setup-row">
                    <select id="global-provider" value="@SelectedProviderId" @onchange="OnProviderChanged">
                        @foreach (var provider in Providers)
                        {
                            <option value="@provider.Id">@provider.DisplayName (@provider.Kind)</option>
                        }
                    </select>
                    <button class="primary-button" @onclick="ApplyModelAsync" disabled="@(!CanApplyModel)">
                        @(IsModelBusy ? "Updating..." : "Apply")
                    </button>
                </div>
                <small>Current provider: @(SelectedProvider?.DisplayName ?? "None")</small>
            </div>

            <div class="setup-field">
                <label for="global-model">Model</label>
                <select id="global-model" @bind="SelectedModelId">
                    @foreach (var model in AvailableModels)
                    {
                        <option value="@model.Id">@model.DisplayName</option>
                    }
                </select>
                <small>Current model: @CurrentModelLabel</small>
            </div>

            <div class="setup-field">
                <label for="api-key">Override API key</label>
                <input id="api-key"
                       type="password"
                       @bind="ApiKeyInput"
                       @bind:event="oninput"
                       placeholder="Paste a key for the selected provider" />
                <small>@(ApiKeyConfigured ? "A saved key is loaded for this provider. Saving will override it." : "No saved key is loaded for this provider yet.")</small>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(SetupFeedback))
        {
            <p class="setup-feedback">@SetupFeedback</p>
        }
    </section>

    <section class="main-grid">
        <div class="panel chat-panel">
            <div class="panel-header">
                <div>
                    <p class="panel-label">Coordinator chat</p>
                    <h3>Ask for work, create agents, and continue the same conversation</h3>
                </div>
            </div>

            <div class="conversation">
                @if (Messages.Count == 0)
                {
                    <div class="empty-state">
                        <strong>No conversation yet</strong>
                        <p>Try: "Create an agent that reviews backend architecture and async flows."</p>
                    </div>
                }
                else
                {
                    @foreach (var message in Messages)
                    {
                        var isUser = message.AuthorId == "user";
                        <article class="@(isUser ? "message message-user" : "message")">
                            <div class="message-meta">
                                <strong>@ResolveAuthor(message.AuthorId)</strong>
                                <span>@message.CreatedAtUtc.ToLocalTime().ToString("HH:mm:ss")</span>
                            </div>
                            <p>@message.Content</p>
                        </article>
                    }
                }
            </div>

            <div class="composer">
                <label for="chat-message">Brief the coordinator</label>
                <textarea id="chat-message" rows="5" @bind="ChatMessage" placeholder="Example: Create an agent that reviews PRs for security regressions, then summarize how it will help the team."></textarea>
                <div class="composer-actions">
                    <span>@(IsBusy ? "Coordinator is working..." : "Ready")</span>
                    <button class="primary-button" @onclick="SendAsync" disabled="@IsBusy">Send</button>
                </div>
            </div>
        </div>

        <div class="panel studio-panel">
            <div class="panel-header">
                <div>
                    <p class="panel-label">Agent studio</p>
                    <h3>Simple specialist list</h3>
                </div>
            </div>

            <div class="studio-form">
                <label for="agent-description">Create directly from the studio if needed</label>
                <textarea id="agent-description" rows="4" @bind="AgentDescription" placeholder="Example: A frontend specialist that critiques mobile layouts and interaction flow."></textarea>
                <button class="primary-button" @onclick="CreateAgentAsync" disabled="@IsBusy">Create agent</button>
            </div>

            <div class="agent-list">
                @if (Agents.Count == 0)
                {
                    <div class="empty-state">
                        <strong>No agents created yet</strong>
                        <p>The coordinator can create them for you from the chat panel.</p>
                    </div>
                }
                else
                {
                    @foreach (var agent in Agents)
                    {
                        <article class="agent-card">
                            <div class="agent-topline">
                                <strong>@agent.Name</strong>
                                <span>@CurrentModelLabel</span>
                            </div>
                            <p class="agent-role">@agent.Description</p>
                        </article>
                    }
                }
            </div>
        </div>
    </section>

    <details class="diagnostics-shell">
        <summary>Diagnostics and agent stream</summary>
        <section class="diagnostics-grid">
            <div class="panel output-panel">
                <div class="panel-header">
                    <div>
                        <p class="panel-label">Agent stream</p>
                        <h3>Relevant coordinator and specialist updates</h3>
                    </div>
                </div>

                <div class="activity-stream">
                    @if (!ProgressFeed.Any())
                    {
                        <div class="empty-state">
                            <strong>No activity yet</strong>
                            <p>Runtime events will appear here as the coordinator receives work and agents respond.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var entry in ProgressFeed)
                        {
                            <article class="activity-entry">
                                <div class="activity-header">
                                    <strong>@entry.Title</strong>
                                    <span>@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                </div>
                                <p>@entry.Message</p>
                            </article>
                        }
                    }
                </div>
            </div>

            <div class="panel exception-panel">
                <div class="panel-header">
                    <div>
                        <p class="panel-label">Debug</p>
                        <h3>Error details and stack traces</h3>
                    </div>
                </div>

                <div class="activity-stream">
                    @if (!ExceptionFeed.Any())
                    {
                        <div class="empty-state">
                            <strong>No failures captured</strong>
                            <p>If an agent run or tool invocation fails, the underlying reason will appear here.</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var entry in ExceptionFeed)
                        {
                            <article class="activity-entry activity-entry-error">
                                <div class="activity-header">
                                    <strong>@entry.Title</strong>
                                    <span>@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                                </div>
                                <p>@entry.Message</p>
                                @if (!string.IsNullOrWhiteSpace(entry.ProviderId) || !string.IsNullOrWhiteSpace(entry.ModelId))
                                {
                                    <p class="activity-meta">
                                        Provider: @entry.ProviderId (@entry.ProviderKind)
                                        @if (!string.IsNullOrWhiteSpace(entry.ModelId))
                                        {
                                            <span> | Model: @entry.ModelId</span>
                                        }
                                    </p>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.ExceptionType) || !string.IsNullOrWhiteSpace(entry.ExceptionMessage))
                                {
                                    <p class="activity-detail">@entry.ExceptionType: @entry.ExceptionMessage</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.Details))
                                {
                                    <p class="activity-detail">@entry.Details</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(entry.ExceptionDetails))
                                {
                                    <pre class="activity-trace">@entry.ExceptionDetails</pre>
                                }
                            </article>
                        }
                    }
                </div>
            </div>
        </section>
    </details>
</div>
