@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="status-page">
    <p class="status-eyebrow">Application error</p>
    <h1>Something went wrong.</h1>
    <p class="status-copy">An error occurred while processing your request.</p>

    @if (ShowRequestId)
    {
        <p class="status-copy">
            <strong>Request ID:</strong> <code>@RequestId</code>
        </p>
    }

    <div class="status-note">
        <h2>Development mode</h2>
        <p>Switching to <strong>Development</strong> shows detailed error information for local debugging.</p>
        <p>Keep production environments out of <strong>Development</strong> so exception details are not exposed to end users.</p>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
